<!DOCTYPE html><html><head><meta name="viewport" content="width=device-width,initial-scale=1"><title>VB AI</title><style>body{background:#000;color:#0f0;font-family:sans-serif;padding:20px;margin:0}#chat{height:70vh;overflow-y:auto;border:2px solid #0f0;padding:10px;margin-bottom:10px;border-radius:10px}input,button{width:100%;padding:14px;background:#111;color:#0f0;border:2px solid #0f0;font-size:16px;border-radius:8px}button{background:#0f0;color:#000;font-weight:bold;margin-top:8px}</style></head><body><h2>🔥 VB AI CHAT</h2><div id="chat">शेर, नमस्ते बोल...</div><input id="msg" placeholder="मैसेज लिख..."><button onclick="send()">भेज दे शेर</button><script>function send(){let m=document.getElementById('msg'),c=document.getElementById('chat');if(!m.value.trim())return;c.innerHTML+=`<br><b>तू:</b> ${m.value}`;let x=m.value;m.value='';setTimeout(()=>c.innerHTML+=`<br><b>AI:</b> शेर, ${x} सुन लिया... अब बोल क्या धमाका करना है?`,700);c.scrollTop=c.scrollHeight}</script></body></html>